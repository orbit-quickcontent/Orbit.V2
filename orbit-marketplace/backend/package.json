{
  "name": "orbit-standalone-backend",
  "version": "1.0.0",
  "description": "Unified standalone Express API and WebSocket backend for Orbit",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node -r tsconfig-paths/register --transpile-only src/server.ts",
    "build": "tsc",
    "start": "ts-node -r tsconfig-paths/register --transpile-only src/server.ts",
    "db:generate": "prisma generate"
  },
  "dependencies": {
    "@prisma/client": "^6.11.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
